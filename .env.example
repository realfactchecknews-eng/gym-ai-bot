# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# URL Cloudflare-воркера (он прячет ключ OpenRouter). Без /chat/completions.
OPENROUTER_BASE_URL=https://gym-openrouter-proxy.your-account.workers.dev

# Общий пароль между ботом и воркером (тот же, что задан секретом воркера)
PROXY_SECRET=придумай-любой-пароль

# Модели OpenRouter (по желанию можно поменять)
TEXT_MODEL=openai/gpt-4o-mini
VISION_MODEL=openai/gpt-4o-mini

# Нужен ТОЛЬКО если ходишь в OpenRouter напрямую, без воркера:
# OPENROUTER_API_KEY=sk-or-...
